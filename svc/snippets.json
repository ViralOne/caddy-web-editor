[
  {
    "name": "Reverse Proxy",
    "description": "Basic reverse proxy to internal IP",
    "code": "example.domain.com {\n    reverse_proxy 10.0.0.1:8080\n}\n"
  },
  {
    "name": "Reverse Proxy + WebSocket",
    "description": "With flush for real-time",
    "code": "example.domain.com {\n    reverse_proxy 10.0.0.1:8080 {\n        flush_interval -1\n    }\n}\n"
  },
  {
    "name": "Security Headers",
    "description": "Standard security headers",
    "code": "    header {\n        X-Frame-Options \"SAMEORIGIN\"\n        X-Content-Type-Options \"nosniff\"\n        Referrer-Policy \"strict-origin-when-cross-origin\"\n        -Server\n    }\n"
  },
  {
    "name": "Cloudflare Only",
    "description": "Block non-Cloudflare IPs (tunnel)",
    "code": "    @blocked not remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22\n    respond @blocked 403\n"
  },
  {
    "name": "Rate Limiting",
    "description": "Limit per IP (needs plugin)",
    "code": "    rate_limit {remote.ip} 100r/m\n"
  },
  {
    "name": "Basic Auth",
    "description": "Password protect (caddy hash-password)",
    "code": "    basicauth {\n        admin $2a$14$HASH_HERE\n    }\n"
  },
  {
    "name": "CORS",
    "description": "Allow cross-origin requests",
    "code": "    header Access-Control-Allow-Origin \"*\"\n    header Access-Control-Allow-Methods \"GET, POST, OPTIONS\"\n    header Access-Control-Allow-Headers \"Content-Type, Authorization\"\n"
  },
  {
    "name": "Static Files",
    "description": "Serve files from directory",
    "code": "example.domain.com {\n    root * /var/www/html\n    file_server\n}\n"
  },
  {
    "name": "SPA",
    "description": "Single page app with fallback",
    "code": "example.domain.com {\n    root * /var/www/app\n    try_files {path} /index.html\n    file_server\n}\n"
  },
  {
    "name": "Compression",
    "description": "Enable gzip + zstd",
    "code": "    encode gzip zstd\n"
  },
  {
    "name": "Access Log",
    "description": "JSON access log per site",
    "code": "    log {\n        output file /var/log/caddy/access.log\n        format json\n    }\n"
  }
]

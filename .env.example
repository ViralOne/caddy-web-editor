# Auth mode: "google" or "cloudflare"
AUTH_MODE=google

# --- Google OAuth (only needed if AUTH_MODE=google) ---
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Cloudflare Access (only needed if AUTH_MODE=cloudflare) ---
# Cloudflare Zero Trust -> Networks -> Tunnels -> your tunnel token
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Restrict to your domain (e.g. yourcompany.com) — works with both auth modes
ALLOWED_DOMAIN=yourcompany.com

# Optional: restrict to specific emails (comma-separated), leave empty for domain-only check
ALLOWED_EMAILS=

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-string

# Caddyfile path (docker mounts test-Caddyfile to /etc/caddy/Caddyfile)
CADDYFILE_PATH=/etc/caddy/Caddyfile

# Backup directory
BACKUP_DIR=/backups
